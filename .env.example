# External data layer (optional)
# URL for the external data layer service. If not set, uses in-process mock repository.
DATA_LAYER_BASE_URL=http://localhost:8088
# Legacy fallback for DATA_LAYER_BASE_URL
MOCKED_DB_BASE_URL=

# Caching layer (optional)
# URL for the caching layer service used for similar-concept search when no vector DB is available
CACHING_LAYER_BASE_URL=http://localhost:8091
# When set to 1 (or true/yes) and CACHING_LAYER_BASE_URL is configured, use cache + graph for similar concept search
USE_CACHE_FOR_SIMILAR=0

# Management Plane (for auto-registration of cognition engines)
# URL of the management plane API (required for cognition engine auto-registration)
# If not set, the gateway will skip registration and log a warning
MGMT_PLANE_URL=http://localhost:9000
# Host where the cognition engine is accessible (defaults to localhost)
COGNITION_ENGINE_HOST=localhost
# Port where the cognition engine is running (defaults to 9004)
COGNITION_ENGINE_PORT=9004

# Azure OpenAI Configuration (required for ingestion extraction)
# Ingestion needs these for LLM-based concept/relationship extraction.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Local embedding model (optional)
# Path to bge-small-en-v1.5 folder. If set, ingestion and evidence use this instead of downloading from Hugging Face.
# Use repo-relative path when running from repo root (e.g. bge-small-en-v1.5) or an absolute path.
# Leave empty to use Hugging Face (or auto-detect repo bge-small-en-v1.5 if present).
EMBEDDING_MODEL_PATH=

# Evidence Gathering Tuning Parameters
# Maximum depth for evidence graph traversal
EG_MAX_DEPTH=4
# Maximum number of paths to explore during evidence gathering
EG_PATH_LIMIT=20
