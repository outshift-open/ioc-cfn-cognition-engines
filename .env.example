# External data layer (optional)
# URL for the external data layer service. If not set, uses in-process mock repository.
DATA_LAYER_BASE_URL=http://localhost:8088
# Legacy fallback for DATA_LAYER_BASE_URL
MOCKED_DB_BASE_URL=

# Management Plane (for auto-registration of cognition engines)
# URL of the management plane API (required for cognition engine auto-registration)
# If not set, the gateway will skip registration and log a warning
MGMT_PLANE_URL=http://localhost:9000
# Host where the cognition engine is accessible (defaults to localhost)
COGNITION_ENGINE_HOST=localhost
# Port where the cognition engine is running (defaults to 9004)
COGNITION_ENGINE_PORT=9004

# Azure OpenAI Configuration (required for ingestion extraction)
# Ingestion needs these for LLM-based concept/relationship extraction.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Local embedding model (optional)
# Path to granite-embedding-30m-english folder. If set, ingestion and evidence use this instead of downloading from Hugging Face.
# Use repo-relative path when running from repo root (e.g. granite-embedding-30m-english) or an absolute path.
# Leave empty to use Hugging Face (or auto-detect repo granite-embedding-30m-english if present).
EMBEDDING_MODEL_PATH=

# Knowledge Processor Configuration (ingestion)
# Enable embedding generation for concepts (true/false, default: true)
ENABLE_EMBEDDINGS=true
# Enable semantic deduplication of concepts and relations (true/false, default: true)
ENABLE_DEDUP=true
# Cosine similarity threshold for deduplication (0.0-1.0, default: 0.95)
# Higher values = stricter matching, lower values = more aggressive deduplication
SIMILARITY_THRESHOLD=0.95

# Evidence Gathering Tuning Parameters
# Maximum depth for evidence graph traversal
EG_MAX_DEPTH=4
# Maximum number of paths to explore during evidence gathering
EG_PATH_LIMIT=20

# Semantic Negotiation Agent
# Hard cap on SAO rounds per session (default: 0 = no cap).
# When unset or 0, the step budget is computed automatically from
# negotiation complexity (n_agents × n_issues × ln(options)).
# Set to a positive integer to enforce an upper bound, e.g.:
# NEGOTIATION_N_STEPS=500
NEGOTIATION_N_STEPS=0

# NegMAS negotiator strategy class name (default: BoulwareTBNegotiator)
# Available: BoulwareTBNegotiator  — holds extreme offer, concedes late (sub-linear)
#            ConcederTBNegotiator  — concedes quickly (super-linear)
#            LinearTBNegotiator    — concedes at a constant linear rate
#            NaiveTitForTatNegotiator — mirrors opponent's concession size
#            SimpleTitForTatNegotiator
#            AspirationNegotiator  — time-based, ignores opponent offers
#            CABNegotiator         — optimal & complete (game-theoretic)
#            CANNegotiator         — optimal conceding-accepting not-worse
#            ToughNegotiator       — never concedes, only its best offer
#            NiceNegotiator        — accepts everything
#            MiCRONegotiator       — minimal rational concession
NEGOTIATOR_STRATEGY=ConcederTBNegotiator
