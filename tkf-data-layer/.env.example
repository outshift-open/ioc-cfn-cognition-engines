# Neo4j - copy this file to .env and set real values locally. Never commit .env.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embeddings (fastembed: use full model id)
TKF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TKF_EMBEDDING_DIMENSIONS=384
TKF_EMBEDDING_BATCH_SIZE=32

# Server
TKF_DATA_LAYER_HOST=0.0.0.0
TKF_DATA_LAYER_PORT=8088

# KCR data (for load script)
# KCR_JSON_PATH=/path/to/KCR_sample1.json
