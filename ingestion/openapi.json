{
  "openapi": "3.1.0",
  "info": {
    "title": "Telemetry Extraction Service",
    "description": "Extracts knowledge from OpenTelemetry data",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/extract/entities_and_relations/batch": {
      "post": {
        "tags": [
          "extraction"
        ],
        "summary": "Extract Entities And Relations Batch",
        "description": "Batch entity & relation extraction (legacy path, new request/response envelope).\n\nPipeline:\n1. Parse structured request body\n2. Extract concepts and relationships\n3. Generate embeddings and optionally deduplicate\n4. Return response in the unified envelope format",
        "operationId": "extract_entities_and_relations_batch_api_v1_extract_entities_and_relations_batch_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/extract/concepts_and_relationships/batch": {
      "post": {
        "tags": [
          "extraction"
        ],
        "summary": "Extract Concepts And Relationships Batch",
        "description": "Batch concept & relationship extraction (legacy path, new request/response envelope).\n\nPipeline:\n1. Parse structured request body\n2. Extract high-level concepts and relationships via LLM\n3. Generate embeddings and optionally deduplicate\n4. Return response in the unified envelope format",
        "operationId": "extract_concepts_and_relationships_batch_api_v1_extract_concepts_and_relationships_batch_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/metrics": {
      "get": {
        "tags": [
          "extraction"
        ],
        "summary": "Get Metrics",
        "description": "Get operational metrics.",
        "operationId": "get_metrics_api_v1_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
