              }
            }
          }
        }
      }
    },
    "/api/v1/extract/entities_and_relations/from_file": {
      "get": {
        "tags": [
          "extraction"
        ],
        "summary": "Extract Entities And Relations From File",
        "description": "Load OTEL data from a JSON file, extract entities and relations,\ngenerate embeddings, and optionally perform semantic deduplication.",
        "operationId": "extract_entities_and_relations_from_file_api_v1_extract_entities_and_relations_from_file_get",
        "parameters": [
          {
            "name": "file_path",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Path"
            }
          },
          {
            "name": "save_output",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Save Output"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/extract/concepts_and_relationships/from_file": {
      "get": {
        "tags": [
          "extraction"
        ],
        "summary": "Extract Concepts And Relationships From File",
        "description": "Load OTEL data from a JSON file and extract high-level concepts and relationships.",
        "operationId": "extract_concepts_and_relationships_from_file_api_v1_extract_concepts_and_relationships_from_file_get",
        "parameters": [
          {
            "name": "file_path",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Path"
            }
          },
          {
            "name": "save_output",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Save Output"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/knowledge-mgmt/extraction": {
      "post": {
        "tags": [
          "knowledge-mgmt"
        ],
        "summary": "Knowledge Extraction",
        "description": "Unified knowledge extraction endpoint.\n\nAccepts a structured request with header, request_id, and a payload\nwhose ``metadata.format`` declares the data format (e.g. 'observe-sdk-otel',\n'openclaw').  All formats are processed through the ConceptRelationship\nextraction pipeline (LLM-based concept and relationship identification).\n\nPipeline:\n1. Validate header and format\n2. Extract concepts and relationships via ConceptRelationshipExtractionService\n3. Generate embeddings and optionally deduplicate\n4. Return response with header echo and response_id",
        "operationId": "knowledge_extraction_api_knowledge_mgmt_extraction_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractionResponseModel"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": [
          "root"
        ],
        "summary": "Root",
        "description": "Root endpoint.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health Check",
        "description": "Health check endpoint.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExtractionError": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "description": "User-meaningful error message"
          },
          "detail": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail",
            "description": "Stack trace or debugging context"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ExtractionError",
        "description": "Error block returned when processing fails."
      },
      "ExtractionHeader": {
        "properties": {
          "workspace_id": {
            "type": "string",
            "title": "Workspace Id",
            "description": "Workspace identifier (mandatory)"
          },
          "mas_id": {
            "type": "string",
            "title": "Mas Id",
            "description": "MAS identifier (mandatory)"
          },
          "agent_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agent Id",
            "description": "Agent identifier (optional)"
          }
        },
        "type": "object",
        "required": [
          "workspace_id",
          "mas_id"
        ],
        "title": "ExtractionHeader",
        "description": "Header for knowledge-mgmt extraction requests."
      },
      "ExtractionPayload": {
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/PayloadMetadata"
          },
          "data": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Data",
            "description": "Array of trace/data records matching the declared format"
          }
        },
        "type": "object",
        "required": [
          "metadata",
          "data"
        ],
        "title": "ExtractionPayload",
        "description": "Payload containing metadata and the raw data records."
      },
      "ExtractionRequest": {
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ExtractionHeader"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id",
            "description": "Client-supplied request ID; service echoes it back as response_id"
          },
          "payload": {
            "$ref": "#/components/schemas/ExtractionPayload"
          }
        },
        "type": "object",
        "required": [
          "header",
          "request_id",
          "payload"
        ],
        "title": "ExtractionRequest",
        "description": "Top-level request body for /api/knowledge-mgmt/extraction."
      },
      "ExtractionResponseModel": {
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ExtractionHeader"
          },
          "response_id": {
            "type": "string",
            "title": "Response Id",
            "description": "Populated from request_id"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExtractionError"
              },
              {
                "type": "null"
              }
            ]
          },
          "concepts": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": true,
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Concepts"
          },
          "relations": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": true,
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Relations"
          },
          "descriptor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Descriptor"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "header",
          "response_id"
        ],
        "title": "ExtractionResponseModel",
        "description": "Unified response for /api/knowledge-mgmt/extraction.\n\nEither ``error`` is present **or** the concepts/relations/descriptor/metadata\nfields are present, but never both."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PayloadFormat": {
        "type": "string",
        "enum": [
          "observe-sdk-otel",
          "openclaw"
        ],
        "title": "PayloadFormat"
      },
      "PayloadMetadata": {
        "properties": {
          "format": {
            "$ref": "#/components/schemas/PayloadFormat",
            "description": "Data format: 'observe-sdk-otel' or 'openclaw'"
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "format"
        ],
        "title": "PayloadMetadata",
        "description": "Metadata describing the payload format and additional labels."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
